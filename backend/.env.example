# Copy to backend/.env and adjust. Defaults target the docker-compose dev db
# (:5433). In containers these are overridden by compose / the host platform.

# --- Datastore ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/backtester

# --- App ---
DEBUG=true

# --- Auth (MUST override in any real deployment; >= 32 bytes for HS256) ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-secret-change-me-in-production-0123456789
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- HTTP hardening ---
# Comma-separated allowed origins, or "*" for any (dev only).
CORS_ORIGINS=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# --- Trading (paper venue) ---
COMMISSION_BPS=0
SLIPPAGE_BPS=5
MAX_LEVERAGE=2.0
SHORT_MARGIN_REQUIREMENT=1.5

# --- Backtests ---
BACKTEST_MEMORY_CAP_MB=4096
BACKTEST_TIME_LIMIT_S=600

# --- Market data (optional; yfinance needs no key) ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_FEED=iex
