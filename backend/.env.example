# Copy to backend/.env and adjust. Defaults target the docker-compose dev infra
# (db on :5433, redis on :6380). In containers these are overridden by compose.

# --- Datastores ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/backtester
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# --- App ---
DEBUG=true

# --- Auth (MUST override in any real deployment; >= 32 bytes for HS256) ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-secret-change-me-in-production-0123456789
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- HTTP hardening ---
# Comma-separated allowed origins, or "*" for any (dev only).
CORS_ORIGINS=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# --- Observability ---
# Web metrics: GET /metrics. The Celery worker serves its own registry here:
WORKER_METRICS_PORT=9200

# --- Market data (optional; yfinance needs no key) ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_FEED=iex
